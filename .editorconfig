# EditorConfig - Estandariza editores
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,xml,yml,yaml}]
indent_style = spaces
indent_size = 4

[*.{md,txt}]
indent_style = spaces
indent_size = 2
trim_trailing_whitespace = false

[*.{json,js}]
indent_style = spaces
indent_size = 2

[pom.xml]
indent_style = spaces
indent_size = 4
